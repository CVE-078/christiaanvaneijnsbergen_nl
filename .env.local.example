# Copy to .env.local and fill in. Never commit real values.

# Supabase project URL and public anon key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key. SERVER ONLY, never prefix with NEXT_PUBLIC_ and never expose
# to the client. Used by src/lib/supabase/admin.ts for account deletion
# (auth.admin.deleteUser). Find it in Supabase: Project Settings > API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site origin (no trailing slash). Used to build auth email redirect
# URLs (signup confirm / password reset) so they never depend on request headers.
# SET THIS IN PRODUCTION. When unset (local dev), the origin falls back to request
# headers. Must match an entry in Supabase Auth's redirect allow-list.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
